# Use when Docker Hub is slow/unreachable: build JAR on host first.
#   mvn -DskipTests package
#   docker compose -f docker-compose.package.yml up -d --build
ARG JRE_IMAGE=docker.m.daocloud.io/library/eclipse-temurin:8-jre-jammy
FROM ${JRE_IMAGE}
WORKDIR /app
RUN mkdir -p /app/uploads
COPY target/hm-dianping-0.0.1-SNAPSHOT.jar app.jar
EXPOSE 8081
ENV SPRING_PROFILES_ACTIVE=docker
ENV IMAGE_UPLOAD_DIR=/app/uploads
ENTRYPOINT ["java", "-jar", "app.jar"]
